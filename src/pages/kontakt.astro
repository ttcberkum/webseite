---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Kontakt" description="So erreichst du den TTC Berkum – per Mail, Telefon oder direkt in der Halle.">
	<PageHeader badge="Kontakt" title="So erreichst du uns" lead="Schreib uns einfach eine kurze E-Mail oder komm zu unseren Trainingszeiten vorbei – wir freuen uns auf dich." />

	<section class="section">
		<div class="container">
			<div class="contact-grid">
				<a href="mailto:ttcberkum@gmail.com" class="contact-card contact-card--primary reveal">
					<span class="contact-card__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
							<polyline points="22,6 12,13 2,6"/>
						</svg>
					</span>
					<div class="contact-card__body">
						<span class="contact-card__label">E-Mail</span>
						<span class="contact-card__value">ttcberkum@gmail.com</span>
						<span class="contact-card__hint">Schreib uns einfach – wir antworten meist innerhalb weniger Tage.</span>
					</div>
				</a>

				<a href="tel:+491724350397" class="contact-card reveal" style="--delay: 80ms">
					<span class="contact-card__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
						</svg>
					</span>
					<div class="contact-card__body">
						<span class="contact-card__label">Telefon · 1. Vorsitzender</span>
						<span class="contact-card__value">+49 172 4350397</span>
						<span class="contact-card__hint">Erik Böker · gerne auch per WhatsApp</span>
					</div>
				</a>

				<div class="contact-card reveal" style="--delay: 160ms">
					<span class="contact-card__icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
							<circle cx="12" cy="10" r="3"/>
						</svg>
					</span>
					<div class="contact-card__body">
						<span class="contact-card__label">Adresse · Sporthalle</span>
						<span class="contact-card__value">Sporthalle Rosenthal<br/>Pechschwarte 64<br/>31226 Peine</span>
						<a href="/trainingszeiten" class="contact-card__hint contact-card__hint--link">Trainingszeiten &amp; Anfahrt →</a>
					</div>
				</div>
			</div>

			<aside class="contact-note reveal" style="--delay: 220ms">
				<p>Du hast noch nie Tischtennis gespielt? Egal! Komm zu einem unserer Trainings vorbei – Schläger und Bälle sind in der Halle, das Schnuppern ist kostenlos.</p>
				<a href="/mitglied-werden" class="btn btn-primary">Mitglied werden</a>
			</aside>
		</div>
	</section>
</BaseLayout>

<style>
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
		margin-bottom: var(--space-16);
	}

	@media (min-width: 768px) {
		.contact-grid { grid-template-columns: repeat(3, 1fr); }
	}

	.contact-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		padding: var(--space-10) var(--space-8);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: inherit;
		transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
	}

	.contact-card:hover {
		transform: translateY(-3px);
		border-color: var(--color-primary);
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
	}

	.contact-card--primary {
		background: var(--color-primary);
		color: #fff;
		border-color: var(--color-primary);
	}

	.contact-card--primary:hover {
		background: var(--color-primary-dark);
		border-color: var(--color-primary-dark);
		box-shadow: 0 12px 28px rgba(200, 16, 46, 0.35);
	}

	.contact-card__icon {
		width: 56px;
		height: 56px;
		display: grid;
		place-items: center;
		border-radius: 14px;
		background: rgba(200, 16, 46, 0.10);
		color: var(--color-primary);
		flex-shrink: 0;
	}

	.contact-card--primary .contact-card__icon {
		background: rgba(255, 255, 255, 0.15);
		color: #fff;
	}

	.contact-card__body {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		flex: 1;
	}

	.contact-card__label {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		opacity: 0.7;
		margin-bottom: var(--space-1);
	}

	.contact-card__value {
		font-family: var(--font-body);
		font-weight: 700;
		font-size: 1.2rem;
		line-height: 1.4;
	}

	.contact-card__hint {
		margin-top: var(--space-4);
		font-size: 0.92rem;
		line-height: 1.55;
		opacity: 0.85;
		text-decoration: none;
		color: inherit;
	}

	.contact-card--primary .contact-card__hint { opacity: 0.92; }

	.contact-card__hint--link {
		font-weight: 700;
		color: var(--color-primary);
	}

	.contact-card__hint--link:hover { text-decoration: underline; }

	.contact-note {
		max-width: 780px;
		margin: 0 auto;
		padding: var(--space-10) var(--space-10);
		background: var(--color-surface-alt);
		border-left: 4px solid var(--color-primary);
		border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-6);
		align-items: flex-start;
	}

	.contact-note p {
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.7;
		color: var(--color-text);
	}

	@media (max-width: 575px) {
		.contact-card { padding: var(--space-8) var(--space-6); }
		.contact-note { padding: var(--space-8) var(--space-7); }
	}
</style>
