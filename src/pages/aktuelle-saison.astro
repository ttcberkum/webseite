---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCurrentSeason } from '../lib/season';

const { slug } = getCurrentSeason();
const base = `https://www.mytischtennis.de/click-tt/TTVN/${slug}/verein/1130350/TTC_Berkum`;

const links = [
	{
		title: 'Mannschaften & Tabellen',
		description: 'Tabellenstand und Punktebilanz aller Mannschaften.',
		href: `${base}/mannschaften`,
		source: 'myTischtennis',
		icon: 'trophy',
	},
	{
		title: 'Spielplan',
		description: 'Termine, Heim- und Auswärtsspiele mit Ergebnissen.',
		href: `${base}/spielplan`,
		source: 'myTischtennis',
		icon: 'calendar',
	},
	{
		title: 'Bilanzen',
		description: 'Einsätze, Siege und Niederlagen pro Spieler:in.',
		href: `${base}/bilanzen/gesamt`,
		source: 'myTischtennis',
		icon: 'chart',
	},
	{
		title: 'Mannschaftsmeldungen',
		description: 'Offizielle Aufstellungen der Mannschaften.',
		href: `${base}/meldungen`,
		source: 'Click-TT',
		icon: 'team',
	},
	{
		title: 'Vereinsinfo',
		description: 'Stammdaten und Ansprechpartner im TTVN-Portal.',
		href: `${base}/info`,
		source: 'Click-TT',
		icon: 'info',
	},
];
---

<BaseLayout title="Aktuelle Saison" description="Mannschaften, Spielpläne und Bilanzen des TTC Berkum – tagesaktuell aus dem TTVN-Portal.">
	<div class="page-header section">
		<div class="container">
			<span class="badge">Spielbetrieb</span>
			<h1>Aktuelle Saison</h1>
			<p class="lead-text">Tabellen, Spielpläne und Bilanzen unserer Mannschaften – tagesaktuell aus dem TTVN-Spielbetrieb.</p>
		</div>
	</div>

	<section class="section">
		<div class="container">
			<div class="link-grid">
				{links.map((link, i) => (
					<a href={link.href} target="_blank" rel="noopener noreferrer" class="club-card reveal" style={`--delay: ${i * 70}ms`}>
						<span class="club-card__icon" aria-hidden="true">
							{link.icon === 'trophy' && (
								<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z"/>
									<path d="M7 6H5a2 2 0 0 0-2 2v1a3 3 0 0 0 3 3h1"/>
									<path d="M17 6h2a2 2 0 0 1 2 2v1a3 3 0 0 1-3 3h-1"/>
								</svg>
							)}
							{link.icon === 'calendar' && (
								<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="3" y="4" width="18" height="18" rx="2"/>
									<line x1="16" y1="2" x2="16" y2="6"/>
									<line x1="8" y1="2" x2="8" y2="6"/>
									<line x1="3" y1="10" x2="21" y2="10"/>
								</svg>
							)}
							{link.icon === 'chart' && (
								<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<line x1="18" y1="20" x2="18" y2="10"/>
									<line x1="12" y1="20" x2="12" y2="4"/>
									<line x1="6" y1="20" x2="6" y2="14"/>
									<line x1="3" y1="20" x2="21" y2="20"/>
								</svg>
							)}
							{link.icon === 'team' && (
								<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
									<circle cx="9" cy="7" r="4"/>
									<path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
									<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
								</svg>
							)}
							{link.icon === 'info' && (
								<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"/>
									<line x1="12" y1="16" x2="12" y2="12"/>
									<line x1="12" y1="8" x2="12.01" y2="8"/>
								</svg>
							)}
						</span>
						<div class="club-card__body">
							<span class="club-card__source">{link.source}</span>
							<h3 class="club-card__title">{link.title}</h3>
							<p class="club-card__desc">{link.description}</p>
						</div>
						<span class="club-card__arrow" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="7" y1="17" x2="17" y2="7"/>
								<polyline points="7 7 17 7 17 17"/>
							</svg>
						</span>
					</a>
				))}
			</div>

			<p class="data-hint reveal">Alle Daten werden zentral im Click-TT-System des TTVN gepflegt. Mit einem Klick öffnet sich die jeweilige Übersicht im offiziellen Portal.</p>
		</div>
	</section>
</BaseLayout>
