---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageSlider from '../components/ImageSlider.astro';

const sliderSlides = [
	{ src: '/images/sascha_henke.jpg', alt: 'Spielbetrieb beim TTC Berkum' },
	{ src: '/images/jugendtraining.jpg', alt: 'Jugendtraining in der Sporthalle Rosenthal' },
	{ src: '/images/benny_weiss.jpg', alt: 'Aktiver Spieler am Tisch' },
];
---

<BaseLayout title="Über uns" description="Lerne den TTC Berkum kennen.">
	<div class="page-header section">
		<div class="container text-center">
			<span class="badge">Seit 1954</span>
			<h1>Unser Verein</h1>
			<p class="lead-text">Mehr als nur ein Tischtennisverein. Wir sind eine Gemeinschaft.</p>
		</div>
	</div>

	<section class="section pt-0">
		<div class="container">
			<div class="about-grid">
				<div class="about-content animate-fade-up">
					<h2>Tischtennis in Peine</h2>
					<p>Der TTC Berkum 1954 e. V. ist seit über sieben Jahrzehnten der Treffpunkt für alle, die in Peine-Berkum gerne den kleinen Zelluloidball übers Netz schicken. Unser Vereinsheim und unsere Trainingsstätte liegen in der Pechschwarte 64 in 31226 Peine.</p>
					<p>Bei uns trainieren Anfängerinnen und Anfänger genauso wie ambitionierte Spielerinnen und Spieler im Punktspielbetrieb. Neben dem Sport leben wir ein reges Vereinsleben mit Vereinsmeisterschaften, Fahrradtouren, Boßeln und gemeinsamen Events.</p>

					<div class="stats-row mt-8">
						<div class="stat-box">
							<span class="stat-number">1954</span>
							<span class="stat-label">Gegründet</span>
						</div>
						<div class="stat-box">
							<span class="stat-number">2×</span>
							<span class="stat-label">Training pro Woche</span>
						</div>
						<div class="stat-box">
							<span class="stat-number">3</span>
							<span class="stat-label">Altersgruppen</span>
						</div>
					</div>
				</div>
				
				<div class="about-visual reveal" style="--delay: 150ms">
					<ImageSlider slides={sliderSlides} interval={5000} ratio="4 / 3" />
				</div>
			</div>
		</div>
	</section>

	<section class="section bg-surface">
		<div class="container">
			<div class="text-center mb-12 animate-fade-up">
				<h2>Der Vorstand</h2>
				<p>Die Gesichter hinter dem TTC Berkum</p>
			</div>
			
			<div class="board-grid">
				<div class="card text-center animate-fade-up delay-100">
					<div class="avatar">EB</div>
					<h3>Erik Böker</h3>
					<p class="role">1. Vorsitzender</p>
					<a href="mailto:erik.boeker@gmail.com" class="email-link">erik.boeker@gmail.com</a>
				</div>
				<div class="card text-center animate-fade-up delay-200">
					<div class="avatar">PK</div>
					<h3>Peter Krätzig</h3>
					<p class="role">2. Vorsitzender</p>
					<a href="mailto:peter.kraetzig@arcor.de" class="email-link">peter.kraetzig@arcor.de</a>
				</div>
				<div class="card text-center animate-fade-up delay-300">
					<div class="avatar">CD</div>
					<h3>Christian Dröse</h3>
					<p class="role">Kassenwart</p>
					<a href="mailto:christian.droese@arcor.de" class="email-link">christian.droese@arcor.de</a>
				</div>
				<div class="card text-center animate-fade-up delay-400">
					<div class="avatar">CeD</div>
					<h3>Cedric Doppelhammer</h3>
					<p class="role">Schriftführer</p>
					<a href="mailto:ceddy.doppelhammer@yahoo.de" class="email-link">ceddy.doppelhammer@yahoo.de</a>
				</div>
				<div class="card text-center animate-fade-up delay-500">
					<div class="avatar">SH</div>
					<h3>Sascha Henke</h3>
					<p class="role">Sportwart</p>
					<a href="mailto:sascha-henke@web.de" class="email-link">sascha-henke@web.de</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}
	
	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }
	.mb-12 { margin-bottom: var(--space-12); }
	.mt-8 { margin-top: var(--space-8); }
	.bg-surface { background-color: var(--color-surface); }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 600px;
		margin: 0 auto;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-12);
		align-items: center;
	}

	@media (min-width: 992px) {
		.about-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-16);
		}
	}

	.stats-row {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-4);
	}

	.stat-box {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		padding: var(--space-4);
		border-radius: 12px;
		text-align: center;
	}

	.stat-number {
		display: block;
		font-size: var(--text-3xl);
		font-weight: 800;
		color: var(--color-primary);
		line-height: 1;
		margin-bottom: var(--space-2);
	}

	.stat-label {
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: 600;
		color: var(--color-text-muted);
	}

	.about-visual {
		width: 100%;
	}

	.board-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: var(--space-8);
	}

	.avatar {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		background: var(--gradient-primary);
		color: white;
		display: grid;
		place-items: center;
		font-size: var(--text-xl);
		font-weight: 700;
		margin: 0 auto var(--space-4);
	}

	.role {
		color: var(--color-primary);
		font-weight: 600;
		margin-bottom: var(--space-2);
	}

	.email-link {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}
</style>
