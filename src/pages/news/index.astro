---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PageHeader from '../../components/PageHeader.astro';

const allNews = await getCollection('news', ({ data }) => import.meta.env.PROD ? !data.draft : true);
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="News" description="Aktuelle Nachrichten und Spielberichte vom TTC Berkum.">
	<PageHeader badge="Aktuelles" title="News & Spielberichte" lead="Bleib auf dem Laufenden rund um unseren Verein." />

	<section class="section pt-0">
		<div class="container">
			<div class="news-grid">
				{sortedNews.map((post) => (
					<article class="news-card card animate-fade-up">
						<div class="card-meta">
							<time datetime={post.data.date.toISOString()}>
								{post.data.date.toLocaleDateString('de-DE', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						</div>
						<h3>
							<a href={`/news/${post.id}`} class="news-link">
								{post.data.title}
							</a>
						</h3>
						{post.data.description && (
							<p class="news-excerpt">{post.data.description}</p>
						)}
						<a href={`/news/${post.id}`} class="read-more">
							Weiterlesen →
						</a>
					</article>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}
	
	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 600px;
		margin: 0 auto;
	}

	.news-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}

	@media (min-width: 768px) {
		.news-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.news-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.news-card {
		padding: var(--space-6);
		display: flex;
		flex-direction: column;
	}

	.card-meta {
		font-size: var(--text-sm);
		color: var(--color-primary);
		font-weight: 600;
		margin-bottom: var(--space-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.news-link {
		text-decoration: none;
		color: var(--color-text);
		transition: color var(--transition-fast);
	}

	.news-link:hover {
		color: var(--color-primary);
	}

	.news-card h3 {
		margin-bottom: var(--space-3);
	}

	.news-excerpt {
		margin-bottom: var(--space-6);
		flex-grow: 1;
	}

	.read-more {
		text-decoration: none;
		color: var(--color-text);
		font-weight: 600;
		font-size: var(--text-sm);
		display: inline-flex;
		align-items: center;
		padding: var(--space-2) var(--space-4);
		background: var(--color-surface-hover);
		border-radius: 100px;
		align-self: flex-start;
		transition: all var(--transition-fast);
	}

	.read-more:hover {
		background: var(--color-primary);
		color: white;
	}
</style>
