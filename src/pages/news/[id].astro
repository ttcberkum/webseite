---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const newsEntries = await getCollection('news');
	return newsEntries.map(entry => ({
		params: { id: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<article class="news-article section">
		<div class="container article-container">
			<header class="article-header animate-fade-up">
				<div class="meta">
					<a href="/news" class="back-link">← Zurück zur Übersicht</a>
					<time datetime={entry.data.date.toISOString()}>
						{entry.data.date.toLocaleDateString('de-DE', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
				</div>
				<h1>{entry.data.title}</h1>
				{entry.data.description && (
					<p class="lead">{entry.data.description}</p>
				)}
			</header>

			<div class="article-content animate-fade-up delay-200">
				<Content />
			</div>
		</div>
	</article>
</BaseLayout>

<style>
	.article-container {
		max-width: 800px;
	}

	.article-header {
		margin-bottom: var(--space-12);
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--color-border);
	}

	.meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: var(--space-6);
		font-size: var(--text-sm);
	}

	.back-link {
		text-decoration: none;
		color: var(--color-primary);
		font-weight: 600;
	}

	.back-link:hover {
		text-decoration: underline;
	}

	time {
		color: var(--color-text-muted);
		font-weight: 500;
	}

	h1 {
		font-size: var(--text-4xl);
		margin-bottom: var(--space-4);
	}

	.lead {
		font-size: var(--text-xl);
		color: var(--color-text-muted);
		line-height: 1.4;
	}

	.article-content {
		font-size: var(--text-lg);
		line-height: 1.7;
	}

	/* Styling for Markdown Content */
	.article-content :global(h2) {
		margin-top: var(--space-12);
		margin-bottom: var(--space-4);
	}

	.article-content :global(h3) {
		margin-top: var(--space-8);
		margin-bottom: var(--space-4);
	}

	.article-content :global(p) {
		margin-bottom: var(--space-6);
	}

	.article-content :global(ul) {
		margin-bottom: var(--space-6);
		padding-left: var(--space-6);
		list-style: disc;
	}

	.article-content :global(li) {
		margin-bottom: var(--space-2);
	}

	.article-content :global(strong) {
		color: var(--color-text);
		font-weight: 700;
	}
</style>
