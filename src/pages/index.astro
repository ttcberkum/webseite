---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageSlider from '../components/ImageSlider.astro';
import UpcomingEvents from '../components/UpcomingEvents.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const impressionen = [
	{ src: '/images/jugendtraining.jpg', alt: 'Jugendtraining in der Sporthalle Rosenthal' },
	{ src: '/images/sascha_henke.jpg', alt: 'Spielbetrieb beim TTC Berkum' },
	{ src: '/images/benny_weiss.jpg', alt: 'Aktiver Spieler am Tisch' },
];
---

<BaseLayout title="Tischtennis in Peine" description="TTC Berkum e. V. – Tischtennis mit Action und Teamgeist. Training für Jugend und Erwachsene in Peine-Berkum seit 1954.">
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "SportsClub",
		"name": "TTC Berkum 1954 e. V.",
		"alternateName": "TTC Berkum",
		"sport": "Tischtennis",
		"url": "https://ttc-berkum.de",
		"logo": "https://ttc-berkum.de/images/logo.svg",
		"image": "https://ttc-berkum.de/images/intro_bg.jpg",
		"foundingDate": "1954",
		"email": "ttcberkum@gmail.com",
		"telephone": "+49-172-4350397",
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "Pechschwarte 64",
			"postalCode": "31226",
			"addressLocality": "Peine",
			"addressRegion": "Niedersachsen",
			"addressCountry": "DE"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 52.3026119,
			"longitude": 10.1646978
		},
		"location": {
			"@type": "Place",
			"name": "Sporthalle Rosenthal",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Pechschwarte 64",
				"postalCode": "31226",
				"addressLocality": "Peine"
			}
		}
	})} />
	<section class="hero">
		<div class="hero-overlay"></div>
		<div class="container hero-container">
			<div class="hero-content animate-fade-up">
				<span class="hero-eyebrow">TTC Berkum e. V. · seit 1954</span>
				<h1 class="hero-title">Tischtennis<br/>in Peine</h1>
				<p class="hero-lead">Tischtennis mit Action und Teamgeist! Egal ob Anfängerin oder ambitionierter Spieler – bei uns bist du richtig.</p>
				<div class="hero-actions">
					<a href="/mitglied-werden" class="btn btn-primary">Mitglied werden</a>
					<a href="/trainingszeiten" class="btn btn-outline-light">Probetraining</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section bierdeckel-section">
		<div class="container">
			<div class="bierdeckel-stage reveal">
				<picture>
					<source srcset="/images/bierdeckel.webp" type="image/webp" />
					<img
						class="bierdeckel-coin"
						src="/images/bierdeckel.png"
						alt="TTC Berkum Bierdeckel"
						width="320"
						height="320"
						loading="lazy"
						decoding="async"
					/>
				</picture>
				<p class="bierdeckel-caption">Seit 1954 · Tischtennis in Peine</p>
			</div>
		</div>
	</section>

	<section class="section section-alt highlights">
		<div class="container">
			<header class="section-head">
				<span class="badge">Was uns ausmacht</span>
				<h2>Mehr als nur Tischtennis</h2>
				<hr class="accent-rule" />
				<p class="lead">Bei uns trainieren Anfänger:innen genauso wie ambitionierte Spieler:innen. Daneben leben wir ein reges Vereinsleben mit Events und Aktionen.</p>
			</header>

			<div class="highlight-grid">
				<article class="highlight-card reveal">
					<div class="icon-circle">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
					</div>
					<h3>Jugend &amp; Erwachsene</h3>
					<p>Training und Wettkämpfe in unterschiedlichen Altersgruppen – von Schnupperkursen bis zum Punktspielbetrieb des TTVN.</p>
				</article>
				<article class="highlight-card reveal" style="--delay: 100ms">
					<div class="icon-circle">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 4h12l-1 8a5 5 0 0 1-10 0L6 4z"/><path d="M9 20h6M12 16v4"/></svg>
					</div>
					<h3>Mehr als nur Sport</h3>
					<p>Punktspiele, Vereinsmeisterschaften, Fahrradtouren, Boßeln und gesellige Events – bei uns kommt das Vereinsleben nicht zu kurz.</p>
				</article>
				<article class="highlight-card reveal" style="--delay: 200ms">
					<div class="icon-circle">
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
					</div>
					<h3>Starke Gemeinschaft</h3>
					<p>Erfahrene Spielerinnen, Nachwuchstalente und Trainingspartner für jedes Niveau – komm vorbei, Tischtennis verbindet!</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section impressions-section">
		<div class="container">
			<header class="section-head reveal">
				<span class="badge">Einblicke</span>
				<h2>Aus dem Vereinsleben</h2>
				<hr class="accent-rule" />
			</header>
			<div class="impressions-wrap reveal" style="--delay: 100ms">
				<ImageSlider slides={impressionen} interval={5000} ratio="16 / 9" />
			</div>
		</div>
	</section>

	<section class="section section-dark training-section">
		<div class="container training-container">
			<div class="training-text reveal">
				<span class="badge">Trainingsplan</span>
				<h2>Wann wird trainiert?</h2>
				<hr class="accent-rule left" />
				<p>Wir trainieren zweimal pro Woche in der Halle in der Pechschwarte 64 in Peine. Samstags bieten wir zusätzlich Kadertraining nach Absprache an.</p>
				<a href="/trainingszeiten" class="btn btn-primary">Alle Trainingszeiten</a>
			</div>

			<div class="training-table reveal" style="--delay: 150ms">
				<table>
					<thead>
						<tr>
							<th>Tag</th>
							<th>Uhrzeit</th>
							<th>Gruppe</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td rowspan="3" class="day-cell">Montag</td>
							<td>17:00 – 18:00</td>
							<td>Anfänger (Jugend)</td>
						</tr>
						<tr>
							<td>18:00 – 19:30</td>
							<td>Jugend</td>
						</tr>
						<tr>
							<td>19:30 – 22:00</td>
							<td>Erwachsene</td>
						</tr>
						<tr>
							<td rowspan="3" class="day-cell">Freitag</td>
							<td>17:00 – 18:00</td>
							<td>Anfänger (Jugend)</td>
						</tr>
						<tr>
							<td>18:00 – 19:30</td>
							<td>Jugend</td>
						</tr>
						<tr>
							<td>19:30 – 22:00</td>
							<td>Erwachsene</td>
						</tr>
						<tr>
							<td class="day-cell">Samstag</td>
							<td>n. A.</td>
							<td>Kadertraining Jüngere</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<section class="section news-section">
		<div class="container">
			<header class="section-head reveal">
				<span class="badge">Aktuelles &amp; Termine</span>
				<h2>Was bei uns los ist</h2>
				<hr class="accent-rule" />
			</header>

			<div class="actuals-grid">
				<div class="actuals-col reveal">
					<UpcomingEvents limit={4} />
				</div>

				<div class="actuals-col reveal" style="--delay: 120ms">
					<header class="actuals-head">
						<span class="badge">Aus dem Verein</span>
						<a href="/news" class="actuals-all">Alle News →</a>
					</header>
					<div class="actuals-news">
						{latestNews.map((post, i) => (
							<article class="news-row" style={`--delay: ${i * 80}ms`}>
								<div class="news-row-meta">
									<time datetime={post.data.date.toISOString()}>
										{post.data.date.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: '2-digit' })}
									</time>
								</div>
								<div class="news-row-body">
									<h3><a href={`/news/${post.id}`}>{post.data.title}</a></h3>
									{post.data.description && <p>{post.data.description}</p>}
								</div>
							</article>
						))}
					</div>
				</div>
			</div>

		</div>
	</section>

	<section class="cta-section section">
		<div class="container">
			<div class="cta-inner">
				<span class="cta-accent" aria-hidden="true"></span>
				<h2>Bereit für den ersten Aufschlag?</h2>
				<p>Komm einfach zu unseren Trainingszeiten vorbei – Schläger und Bälle sind in der Halle. Tischtennis verbindet!</p>
				<div class="cta-actions">
					<a href="/kontakt" class="btn btn-primary">Kontakt aufnehmen</a>
					<a href="/trainingszeiten" class="btn btn-outline">Trainingszeiten</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ===== Hero ===== */
	.hero {
		position: relative;
		min-height: clamp(480px, 70vh, 720px);
		background-image: url('/images/intro_bg.jpg');
		background-size: cover;
		background-position: center;
		color: #fff;
		display: flex;
		align-items: center;
		overflow: hidden;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: var(--gradient-hero-overlay);
		z-index: 1;
	}

	.hero-container {
		position: relative;
		z-index: 2;
		padding-top: var(--space-16);
		padding-bottom: var(--space-16);
	}

	.hero-content {
		max-width: 720px;
	}

	.hero-eyebrow {
		display: inline-block;
		font-family: var(--font-body);
		font-size: 0.95rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		font-weight: 700;
		color: var(--color-primary);
		margin-bottom: var(--space-4);
	}

	.hero-title {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: var(--text-hero);
		line-height: 0.95;
		letter-spacing: 0.005em;
		text-transform: uppercase;
		color: #fff;
		margin-bottom: var(--space-5);
		text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
	}

	.hero-lead {
		font-size: var(--text-lg);
		color: #f0e2e2;
		max-width: 560px;
		margin-bottom: var(--space-8);
	}

	.hero-actions {
		display: flex;
		gap: var(--space-3);
		flex-wrap: wrap;
	}

	/* ===== Bierdeckel-Section ===== */
	.bierdeckel-section {
		padding-top: var(--space-12);
		padding-bottom: var(--space-12);
		background: var(--color-surface);
	}

	.bierdeckel-stage {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-5);
		perspective: 1200px;
		/* Override globales .reveal — Stage selbst soll sich nicht bewegen,
		   nur der Bierdeckel innen wird animiert. */
		opacity: 1;
		transform: none;
		transition: none;
	}

	.bierdeckel-coin {
		width: clamp(180px, 28vw, 320px);
		height: auto;
		aspect-ratio: 1;
		filter: drop-shadow(0 22px 34px rgba(0, 0, 0, 0.28));
		transform-origin: center center;
		opacity: 0;
		transform: scale(2.4) rotate(-540deg);
		will-change: transform, opacity;
		transition: filter var(--transition-normal);
	}

	.bierdeckel-stage.is-visible .bierdeckel-coin {
		animation: bierdeckel-spin-in 1.4s cubic-bezier(0.22, 1.4, 0.36, 1) forwards;
	}

	@keyframes bierdeckel-spin-in {
		0%   { transform: scale(2.4) rotate(-540deg); opacity: 0; }
		55%  { opacity: 1; }
		70%  { transform: scale(0.92) rotate(12deg); opacity: 1; }
		85%  { transform: scale(1.04) rotate(-5deg); }
		100% { transform: scale(1) rotate(-6deg); opacity: 1; }
	}

	.bierdeckel-coin:hover {
		animation: bierdeckel-wobble 0.7s ease-in-out;
		filter: drop-shadow(0 28px 40px rgba(0, 0, 0, 0.32));
	}

	@keyframes bierdeckel-wobble {
		0%, 100% { transform: scale(1) rotate(-6deg); }
		25% { transform: scale(1.04) rotate(4deg); }
		50% { transform: scale(1.04) rotate(-16deg); }
		75% { transform: scale(1.04) rotate(2deg); }
	}

	.bierdeckel-caption {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(1.1rem, 1rem + 0.6vw, 1.5rem);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-text);
		margin: 0;
		text-align: center;
	}

	@media (prefers-reduced-motion: reduce) {
		.bierdeckel-coin {
			opacity: 1;
			transform: rotate(-6deg);
			animation: none !important;
		}
	}

	/* ===== Section Head ===== */
	.section-head {
		text-align: center;
		max-width: 720px;
		margin: 0 auto var(--space-12);
	}

	.section-head .lead {
		color: var(--color-text-muted);
		font-size: var(--text-lg);
	}

	/* ===== Impressionen-Section ===== */
	.impressions-section {
		padding-top: var(--space-16);
		padding-bottom: var(--space-16);
	}

	.impressions-wrap {
		max-width: 960px;
		margin: 0 auto;
	}

	/* ===== Highlights ===== */
	.highlight-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
	}

	@media (min-width: 768px) {
		.highlight-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.highlight-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-10) var(--space-8);
		text-align: center;
		transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
	}

	.highlight-card:hover {
		transform: translateY(-6px);
		border-color: var(--color-primary);
		box-shadow: var(--shadow-md);
	}

	.icon-circle {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: rgba(200, 16, 46, 0.10);
		color: var(--color-primary);
		display: grid;
		place-items: center;
		margin: 0 auto var(--space-5);
	}

	.highlight-card h3 {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.75rem;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--color-primary);
		text-align: center;
	}

	.highlight-card p { text-align: center; }

	/* ===== Training-Section ===== */
	.training-container {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-10);
		align-items: center;
	}

	@media (min-width: 992px) {
		.training-container {
			grid-template-columns: 1fr 1.2fr;
			gap: var(--space-16);
		}
	}

	.training-text h2 { text-align: left; }
	.training-text p { font-size: var(--text-lg); color: var(--color-text-on-dark-muted); margin-bottom: var(--space-6); }

	.training-table {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.training-table table {
		width: 100%;
		border-collapse: collapse;
	}

	.training-table th,
	.training-table td {
		padding: var(--space-4) var(--space-5);
		text-align: left;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.training-table th {
		font-family: var(--font-display);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-primary);
		font-size: 0.95rem;
		background: rgba(255, 255, 255, 0.04);
	}

	.training-table tbody tr:last-child td {
		border-bottom: none;
	}

	.training-table .day-cell {
		font-family: var(--font-display);
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-size: 1.25rem;
		color: #fff;
		vertical-align: middle;
		border-right: 2px solid var(--color-primary);
	}

	/* ===== Aktuelles & Termine (2-Spalten) ===== */
	.actuals-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-10);
	}

	@media (min-width: 992px) {
		.actuals-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-12);
		}
	}

	.actuals-col { display: flex; flex-direction: column; gap: var(--space-5); }

	.actuals-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--space-4);
		flex-wrap: wrap;
	}

	.actuals-head .badge { margin-bottom: 0; }

	.actuals-all {
		text-decoration: none;
		color: var(--color-primary);
		font-weight: 700;
		font-size: 0.9rem;
	}

	.actuals-all:hover { text-decoration: underline; }

	.actuals-news {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.news-row {
		display: grid;
		grid-template-columns: 90px 1fr;
		gap: var(--space-4);
		padding: var(--space-4) var(--space-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		transition: border-color var(--transition-normal), box-shadow var(--transition-normal), transform var(--transition-normal);
	}

	.news-row:hover {
		border-color: var(--color-primary);
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06);
	}

	.news-row-meta time {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 700;
		color: var(--color-primary);
	}

	.news-row-body h3 {
		font-family: var(--font-body);
		font-weight: 700;
		font-size: 1.05rem;
		text-transform: none;
		letter-spacing: 0;
		color: var(--color-text);
		margin: 0 0 var(--space-1);
		line-height: 1.35;
	}

	.news-row-body h3 a {
		text-decoration: none;
		color: inherit;
	}

	.news-row-body h3 a:hover { color: var(--color-primary); }

	.news-row-body p {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.5;
	}

	/* ===== News (legacy 3-Spalten, falls woanders benötigt) ===== */
	.news-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
	}

	@media (min-width: 768px) {
		.news-grid { grid-template-columns: repeat(3, 1fr); }
	}

	.news-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-8);
		display: flex;
		flex-direction: column;
		transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
	}

	.news-card:hover {
		transform: translateY(-4px);
		border-color: var(--color-primary);
		box-shadow: var(--shadow-md);
	}

	.news-meta {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--color-primary);
		font-weight: 700;
		margin-bottom: var(--space-3);
	}

	.news-card h3 {
		color: var(--color-text);
		font-family: var(--font-body);
		font-weight: 700;
		font-size: 1.25rem;
		margin-bottom: var(--space-3);
	}

	.news-card h3 a {
		text-decoration: none;
		color: inherit;
	}

	.news-card h3 a:hover { color: var(--color-primary); }

	.news-card p { flex-grow: 1; }

	.read-more {
		text-decoration: none;
		color: var(--color-primary);
		font-weight: 700;
		margin-top: var(--space-4);
	}

	.read-more:hover { color: var(--color-primary-dark); }

	.news-cta {
		text-align: center;
		margin-top: var(--space-10);
	}

	/* ===== CTA (dezent, nicht großflächig farbig) ===== */
	.cta-section {
		background: var(--color-surface);
		padding: var(--space-16) 0;
	}

	.cta-inner {
		text-align: center;
