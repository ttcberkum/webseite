---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Storchencam Berkum" description="Live-Blick in das Storchennest in Berkum.">
	<div class="page-header section">
		<div class="container text-center">
			<span class="badge">Live</span>
			<h1>Storchencam Berkum</h1>
			<p class="lead-text">Ein Blick in die Natur unseres Dorfes.</p>
		</div>
	</div>

	<section class="section pt-0">
		<div class="container">
			<div class="card glass-panel text-center" style="max-width: 800px; margin: 0 auto;">
				<h2>Das Storchennest</h2>
				<p style="margin-bottom: 2rem;">In Kooperation mit der Gemeinde präsentieren wir hier das Live-Bild aus dem Berkumer Storchennest. Das Bild wird regelmäßig aktualisiert.</p>
				
				<div class="cam-placeholder">
					<div class="cam-overlay">
						<span class="live-badge">LIVE</span>
						<span class="location">Peine-Berkum</span>
					</div>
					<div class="abstract-nest">
						<div class="nest-circle"></div>
						<div class="stork stork-1"></div>
						<div class="stork stork-2"></div>
					</div>
					<div class="cam-info">
						<p>Bildquelle: Gemeinde Peine / Storchencam</p>
					</div>
				</div>

				<div style="margin-top: 3rem;">
					<a href="https://ttc-berkum.de/index.php/sonstiges/storchencam-berkum" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Zur Original-Webcam (extern)</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}
	
	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 600px;
		margin: 0 auto;
	}

	.cam-placeholder {
		background: #2a2a2a;
		border-radius: 16px;
		aspect-ratio: 16/9;
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		color: white;
	}

	.cam-overlay {
		position: absolute;
		top: 1rem;
		left: 1rem;
		right: 1rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		z-index: 2;
	}

	.live-badge {
		background: #ff0000;
		padding: 4px 12px;
		border-radius: 4px;
		font-weight: 800;
		font-size: 0.75rem;
		animation: blink 2s infinite;
	}

	@keyframes blink {
		0% { opacity: 1; }
		50% { opacity: 0.5; }
		100% { opacity: 1; }
	}

	.location {
		font-size: 0.875rem;
		font-weight: 500;
		text-shadow: 0 2px 4px rgba(0,0,0,0.5);
	}

	.abstract-nest {
		position: relative;
		width: 100%;
		height: 100%;
		opacity: 0.3;
	}

	.nest-circle {
		position: absolute;
		bottom: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 300px;
		height: 150px;
		background: #8b4513;
		border-radius: 50%;
	}

	.stork {
		position: absolute;
		background: white;
		width: 40px;
		height: 80px;
		border-radius: 20px;
	}

	.stork::after {
		content: '';
		position: absolute;
		top: 10px;
		right: -10px;
		width: 20px;
		height: 5px;
		background: orange;
	}

	.stork-1 { left: 40%; top: 30%; }
	.stork-2 { right: 40%; top: 40%; transform: rotate(-5deg); }

	.cam-info {
		position: absolute;
		bottom: 1rem;
		left: 1rem;
		font-size: 0.75rem;
		opacity: 0.7;
	}
</style>
