---
import BaseLayout from '../layouts/BaseLayout.astro';

const schedule = [
	{
		day: 'Montag',
		blocks: [
			{ time: '17:00 – 18:00', group: 'Anfänger (Jugend)', accent: 'youth' },
			{ time: '18:00 – 19:30', group: 'Jugend', accent: 'youth' },
			{ time: '19:30 – 22:00', group: 'Erwachsene', accent: 'adult' },
		],
	},
	{
		day: 'Freitag',
		blocks: [
			{ time: '17:00 – 18:00', group: 'Anfänger (Jugend)', accent: 'youth' },
			{ time: '18:00 – 19:30', group: 'Jugend', accent: 'youth' },
			{ time: '19:30 – 22:00', group: 'Erwachsene', accent: 'adult' },
		],
	},
	{
		day: 'Samstag',
		blocks: [
			{ time: 'Nach Absprache', group: 'Kadertraining Jüngere', accent: 'kader' },
		],
	},
];
---

<BaseLayout title="Trainingszeiten" description="Trainingszeiten und Hallenadresse des TTC Berkum.">
	<div class="page-header section">
		<div class="container text-center">
			<span class="badge">Trainingsplan</span>
			<h1>Trainingszeiten</h1>
			<p class="lead-text">Zweimal pro Woche feste Trainingszeiten – plus Kadertraining am Samstag nach Absprache.</p>
		</div>
	</div>

	<section class="section pt-0">
		<div class="container">
			<div class="schedule-grid">
				{schedule.map((day, i) => (
					<div class={`schedule-card card animate-fade-up delay-${i * 100}`}>
						<div class="card-header">
							<h2>{day.day}</h2>
						</div>
						<ul class="block-list">
							{day.blocks.map((block) => (
								<li class={`block ${block.accent}`}>
									<span class="time">{block.time}</span>
									<span class="group">{block.group}</span>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>

			<div class="hall-info card glass-panel animate-fade-up delay-300">
				<div class="hall-grid">
					<div>
						<span class="badge">Halle</span>
						<h2>Sporthalle Rosenthal</h2>
						<p>Pechschwarte 64<br/>31226 Peine</p>
						<p class="small">In der Sporthalle Rosenthal stehen unsere Tische bereit – Schläger und Bälle sind für das Schnuppertraining vorhanden.</p>
						<a href="https://www.google.com/maps/search/?api=1&query=Pechschwarte+64+31226+Peine" target="_blank" rel="noopener noreferrer" class="btn btn-outline">In Google Maps öffnen</a>
					</div>
					<div class="hall-cta">
						<h3>Lust auf ein Probetraining?</h3>
						<p>Komm einfach zu einer Trainingszeit vorbei – wir freuen uns auf dich. Vorab eine kurze Mail oder ein Anruf hilft uns bei der Planung.</p>
						<div class="cta-buttons">
							<a href="mailto:ttcberkum@gmail.com" class="btn btn-primary">E-Mail schreiben</a>
							<a href="/kontakt" class="btn btn-outline">Kontaktseite</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}

	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 640px;
		margin: 0 auto;
	}

	.schedule-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
		margin-bottom: var(--space-12);
	}

	@media (min-width: 768px) {
		.schedule-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.schedule-card {
		padding: 0;
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.schedule-card .card-header {
		background: var(--gradient-primary);
		color: white;
		padding: var(--space-5) var(--space-6);
	}

	.schedule-card .card-header h2 {
		margin: 0;
		color: white;
		font-size: var(--text-xl);
	}

	.block-list {
		list-style: none;
		padding: var(--space-2);
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	.block {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		padding: var(--space-4) var(--space-5);
		border-radius: 12px;
		border-left: 3px solid transparent;
	}

	.block + .block {
		margin-top: var(--space-1);
	}

	.block.youth { border-left-color: var(--color-accent); }
	.block.adult { border-left-color: var(--color-primary); }
	.block.kader { border-left-color: var(--color-text-muted); }

	.block .time {
		font-weight: 700;
		color: var(--color-text);
	}

	.block .group {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.hall-info {
		padding: var(--space-10);
		border-radius: 24px;
	}

	.hall-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}

	@media (min-width: 768px) {
		.hall-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-12);
		}
	}

	.hall-info h2 {
		margin: var(--space-2) 0 var(--space-3);
	}

	.hall-info p {
		margin-bottom: var(--space-4);
	}

	.hall-info p.small {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.hall-cta h3 {
		margin-bottom: var(--space-3);
	}

	.cta-buttons {
		display: flex;
		gap: var(--space-3);
		flex-wrap: wrap;
		margin-top: var(--space-4);
	}
</style>
