---
import BaseLayout from '../layouts/BaseLayout.astro';

const schedule = [
	{
		day: 'Montag',
		blocks: [
			{ time: '17:00 – 18:00', group: 'Anfänger (Jugend)', accent: 'youth' },
			{ time: '18:00 – 19:30', group: 'Jugend', accent: 'youth' },
			{ time: '19:30 – 22:00', group: 'Erwachsene', accent: 'adult' },
		],
	},
	{
		day: 'Freitag',
		blocks: [
			{ time: '17:00 – 18:00', group: 'Anfänger (Jugend)', accent: 'youth' },
			{ time: '18:00 – 19:30', group: 'Jugend', accent: 'youth' },
			{ time: '19:30 – 22:00', group: 'Erwachsene', accent: 'adult' },
		],
	},
	{
		day: 'Samstag',
		blocks: [
			{ time: 'Nach Absprache', group: 'Kadertraining Jüngere', accent: 'kader' },
		],
	},
];
---

<BaseLayout title="Trainingszeiten" description="Trainingszeiten und Hallenadresse des TTC Berkum.">
	<div class="page-header section">
		<div class="container text-center">
			<span class="badge">Trainingsplan</span>
			<h1>Trainingszeiten</h1>
			<p class="lead-text">Zweimal pro Woche feste Trainingszeiten – plus Kadertraining am Samstag nach Absprache.</p>
		</div>
	</div>

	<section class="section pt-0">
		<div class="container">
			<div class="schedule-grid">
				{schedule.map((day, i) => (
					<div class={`schedule-card card animate-fade-up delay-${i * 100}`}>
						<div class="card-header">
							<h2>{day.day}</h2>
						</div>
						<ul class="block-list">
							{day.blocks.map((block) => (
								<li class={`block ${block.accent}`}>
									<span class="time">{block.time}</span>
									<span class="group">{block.group}</span>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>

			<div class="hall-info card glass-panel animate-fade-up delay-300">
				<div class="hall-grid">
					<div>
						<span class="badge">Halle</span>
						<h2>Sporthalle Rosenthal</h2>
						<p>Pechschwarte 64<br/>31226 Peine</p>
						<p class="small">In der Sporthalle Rosenthal stehen unsere Tische bereit – Schläger und Bälle sind für das Schnuppertraining vorhanden.</p>
						<a href="https://www.google.com/maps/search/?api=1&query=Pechschwarte+64+31226+Peine" target="_blank" rel="noopener noreferrer" class="btn btn-outline">In Google Maps öffnen</a>
					</div>
					<div class="hall-cta">
						<h3>Lust auf ein Probetraining?</h3>
						<p>Komm einfach zu einer Trainingszeit vorbei – wir freuen uns auf dich.</p>
						<div class="cta-buttons">
							<a href="mailto:ttcberkum@gmail.com" class="btn btn-primary">E-Mail schreiben</a>
							<a href="/kontakt" class="btn btn-outline">Kontaktseite</a>
						</div>
					</div>
				</div>
			</div>

			<div class="hall-map animate-fade-up delay-400">
				<iframe
					title="Karte: Sporthalle Rosenthal, Pechschwarte 64, Peine"
					src="https://www.openstreetmap.org/export/embed.html?bbox=10.1547%2C52.2986%2C10.1747%2C52.3066&layer=mapnik&marker=52.3026119%2C10.1646978"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
				></iframe>

				<div class="hall-routing">
					<span class="hall-routing-label">Route planen ab deinem Standort:</span>
					<div class="hall-routing-actions">
						<a
							class="route-btn"
							href="https://graphhopper.com/maps/?point=&point=52.3026119%2C10.1646978&profile=car&locale=de"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Routenplanung Auto öffnen"
						>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 17h14M6 11l2-5h8l2 5M7 11h10v6H7z"/>
								<circle cx="8.5" cy="14.5" r="1"/>
								<circle cx="15.5" cy="14.5" r="1"/>
							</svg>
							Auto
						</a>
						<a
							class="route-btn"
							href="https://graphhopper.com/maps/?point=&point=52.3026119%2C10.1646978&profile=bike&locale=de"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Routenplanung Fahrrad öffnen"
						>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="5.5" cy="17.5" r="3.5"/>
								<circle cx="18.5" cy="17.5" r="3.5"/>
								<path d="M15 6h3M9 18l4-9 4 9M9 18l-3-5"/>
							</svg>
							Fahrrad
						</a>
						<a
							class="route-btn"
							href="https://graphhopper.com/maps/?point=&point=52.3026119%2C10.1646978&profile=foot&locale=de"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Routenplanung zu Fuß öffnen"
						>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="13" cy="4" r="2"/>
								<path d="M9 22l3-7 3 4 4-1M9 12l3-4 3 4M7 17l4-2"/>
							</svg>
							Zu Fuß
						</a>
					</div>
				</div>

				<a
					class="hall-map-link"
					href="https://www.openstreetmap.org/?mlat=52.3026119&mlon=10.1646978#map=17/52.3026119/10.1646978"
					target="_blank"
					rel="noopener noreferrer"
				>Größere Karte auf OpenStreetMap öffnen ↗</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}

	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 640px;
		margin: 0 auto;
	}

	.schedule-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
		margin-bottom: var(--space-12);
	}

	@media (min-width: 768px) {
		.schedule-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.schedule-card {
		padding: 0;
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.schedule-card .card-header {
		background: var(--gradient-primary);
		color: white;
		padding: var(--space-5) var(--space-6);
	}

	.schedule-card .card-header h2 {
		margin: 0;
		color: white;
		font-size: var(--text-xl);
	}

	.block-list {
		list-style: none;
		padding: var(--space-2);
		margin: 0;
		display: flex;
		flex-direction: column;
	}

	.block {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		padding: var(--space-4) var(--space-5);
		border-radius: 12px;
		border-left: 3px solid transparent;
	}

	.block + .block {
		margin-top: var(--space-1);
	}

	.block.youth { border-left-color: var(--color-accent); }
	.block.adult { border-left-color: var(--color-primary); }
	.block.kader { border-left-color: var(--color-text-muted); }

	.block .time {
		font-weight: 700;
		color: var(--color-text);
	}

	.block .group {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.hall-info {
		padding: var(--space-10);
		border-radius: 24px;
	}

	.hall-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}

	@media (min-width: 768px) {
		.hall-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-12);
		}
	}

	.hall-info h2 {
		margin: var(--space-2) 0 var(--space-3);
	}

	.hall-info p {
		margin-bottom: var(--space-4);
	}

	.hall-info p.small {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.hall-cta h3 {
		margin-bottom: var(--space-3);
	}

	.cta-buttons {
		display: flex;
		gap: var(--space-3);
		flex-wrap: wrap;
		margin-top: var(--space-4);
	}

	.hall-map {
		margin-top: var(--space-8);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 24px;
		overflow: hidden;
		position: relative;
	}

	.hall-map iframe {
		display: block;
		width: 100%;
		height: clamp(280px, 38vw, 420px);
		border: 0;
		filter: saturate(0.9);
	}

	.hall-routing {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-3) var(--space-5);
		padding: var(--space-4) var(--space-5);
		border-top: 1px solid var(--color-border);
		background: var(--color-surface-alt);
	}

	.hall-routing-label {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		font-weight: 600;
	}

	.hall-routing-actions {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	.route-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 100px;
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--color-text);
		text-decoration: none;
		transition: background-color var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
	}

	.route-btn svg { color: var(--color-primary); flex-shrink: 0; }

	.route-btn:hover {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: #fff;
		transform: translateY(-1px);
	}

	.route-btn:hover svg { color: #fff; }

	.hall-map-link {
		display: block;
		padding: var(--space-3) var(--space-5);
		font-size: 0.85rem;
		color: var(--color-text-muted);
		text-decoration: none;
		text-align: right;
		border-top: 1px solid var(--color-border);
		background: var(--color-surface);
		transition: color var(--transition-fast), background-color var(--transition-fast);
	}

	.hall-map-link:hover {
		color: var(--color-primary);
		background: var(--color-surface-alt);
	}
</style>
