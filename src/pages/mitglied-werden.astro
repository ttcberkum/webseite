---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mitglied werden" description="Werde Mitglied beim TTC Berkum e. V. – Tischtennis mit Action und Teamgeist!">
	<div class="page-header section">
		<div class="container text-center">
			<span class="badge">Mitgliedschaft</span>
			<h1>Werde Teil unserer Gemeinschaft</h1>
			<p class="lead-text">Tischtennis verbindet! Wir freuen uns auf dich.</p>
		</div>
	</div>

	<section class="section pt-0">
		<div class="container">
			<div class="grid">
				<div class="card animate-fade-up">
					<h2>Deine Vorteile</h2>
					<ul class="benefit-list">
						<li>Regelmäßiges Training für alle Leistungsklassen</li>
						<li>Teilnahme am Punktspielbetrieb</li>
						<li>Teilnahme an Vereinsmeisterschaften und Events</li>
						<li>Fahrradtouren, Boßeln und geselliges Beisammensein</li>
						<li>Starke Gemeinschaft mit erfahrenen Partnern</li>
					</ul>
				</div>

				<div class="card animate-fade-up delay-100">
					<h2>Mitgliedsbeiträge</h2>
					<div class="fees">
						<div class="fee-item">
							<span class="label">Erwachsene</span>
							<span class="amount">90,00 € <small>pro Jahr</small></span>
						</div>
						<div class="fee-item">
							<span class="label">Jugendliche</span>
							<span class="amount">60,00 € <small>pro Jahr</small></span>
						</div>
					</div>
					<p class="info-text">Die Beiträge werden jährlich per Lastschrift eingezogen.</p>
				</div>
			</div>

			<div class="cta-box glass-panel animate-fade-up delay-200" style="margin-top: 3rem;">
				<h2>Jetzt online anmelden</h2>
				<p>Der schnellste Weg in unseren Verein: Nutze unser Online-Anmeldeformular.</p>
				<div style="margin-top: 2rem;">
					<a href="/kontakt" class="btn btn-primary">Zum Anmeldeformular</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}
	
	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 600px;
		margin: 0 auto;
	}

	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}

	@media (min-width: 768px) {
		.grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.benefit-list {
		margin-top: 1.5rem;
		list-style: none;
		padding: 0;
	}

	.benefit-list li {
		position: relative;
		padding-left: 2rem;
		margin-bottom: 1rem;
		line-height: 1.4;
	}

	.benefit-list li::before {
		content: '🏓';
		position: absolute;
		left: 0;
		top: 0;
	}

	.fees {
		margin-top: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.fee-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--color-border);
	}

	.fee-item .label {
		font-weight: 700;
		font-size: var(--text-lg);
	}

	.fee-item .amount {
		font-weight: 800;
		font-size: var(--text-2xl);
		color: var(--color-primary);
	}

	.fee-item .amount small {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
		font-weight: 400;
		display: block;
		text-align: right;
	}

	.info-text {
		margin-top: 1.5rem;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.cta-box {
		padding: var(--space-12);
		text-align: center;
		border-radius: 24px;
	}
</style>
