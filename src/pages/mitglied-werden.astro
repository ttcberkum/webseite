---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactLink from '../components/ContactLink.astro';
---

<BaseLayout title="Mitglied werden" description="Werde Mitglied beim TTC Berkum e. V. – Anmeldung direkt online über das Vereinsportal.">
	<PageHeader badge="Mitgliedschaft" title="Mitglied werden" lead="Anmeldung direkt online: einfach das Formular ausfüllen und absenden. Wir melden uns kurz darauf bei dir." />

	<section class="section signup">
		<div class="container">
			<div class="intro">
				<p>Lieber persönlich vorbeischauen? Komm einfach zu unseren <a href="/trainingszeiten">Trainingszeiten</a> – Schläger und Bälle sind in der Halle. Fragen gerne an <ContactLink type="mail" user="ttcberkum" domain="gmail.com" />.</p>
			</div>

			<div class="signup-frame">
				<iframe
					title="Anmeldeformular für neue Mitglieder (spg-direkt)"
					src="https://online.spg-direkt.de/start/164f40c3-0736-4d21-a972-d4fb11c237aa"
					width="100%"
					height="800"
					loading="lazy"
				></iframe>
			</div>

			<p class="hint">Das Anmeldeformular wird über das externe Portal <em>spg-direkt.de</em> bereitgestellt. Bei technischen Problemen mit dem Formular schreib uns einfach eine kurze Mail an <ContactLink type="mail" user="ttcberkum" domain="gmail.com" />.</p>
		</div>
	</section>
</BaseLayout>

<style>
	.intro {
		max-width: 720px;
		margin: 0 auto var(--space-10);
		text-align: center;
	}

	.intro p {
		font-size: var(--text-lg);
	}

	.intro a {
		color: var(--color-primary);
		font-weight: 700;
		text-decoration: none;
	}

	.intro a:hover { text-decoration: underline; }

	.signup-frame {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}

	.signup-frame iframe {
		display: block;
		width: 100%;
		height: 800px;
		border: 0;
		background: #fff;
	}

	.hint {
		max-width: 720px;
		margin: var(--space-8) auto 0;
		text-align: center;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.hint a {
		color: var(--color-primary);
		font-weight: 600;
	}

	@media (max-width: 575px) {
		.signup-frame iframe { height: 1000px; }
	}
</style>
