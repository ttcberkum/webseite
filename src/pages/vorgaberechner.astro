---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout title="Vorgaberechner" description="Berechne die Punkte-Vorgabe für vereinsinterne Turniere.">
	<PageHeader badge="Tool" title="Vorgaberechner" lead="Berechne die Punkte-Vorgabe basierend auf den TTR-Werten." />

	<section class="section pt-0">
		<div class="container">
			<div class="card glass-panel" style="max-width: 600px; margin: 0 auto;">
				<p style="margin-bottom: 2rem; text-align: center;">Gib die TTR-Werte der beiden Spieler ein, um die empfohlene Vorgabe pro Satz zu berechnen.</p>
				
				<div class="calculator-box">
					<div class="form-group">
						<label for="ttr1">TTR Spieler 1 (stärker)</label>
						<input type="number" id="ttr1" placeholder="z.B. 1650" />
					</div>
					<div class="form-group">
						<label for="ttr2">TTR Spieler 2 (schwächer)</label>
						<input type="number" id="ttr2" placeholder="z.B. 1420" />
					</div>
					
					<div class="result-box" id="vorgabe-result">
						<span class="label">Vorgabe pro Satz:</span>
						<span class="value">0</span>
					</div>
				</div>

				<div class="info-note" style="margin-top: 2rem;">
					<p><small>Hinweis: Die Berechnung basiert auf der Formel: 1 Punkt Vorgabe pro 80 TTR-Punkte Differenz (max. 5 Punkte).</small></p>
				</div>
			</div>
		</div>
	</section>

	<script>
		const ttr1Input = document.getElementById('ttr1') as HTMLInputElement;
		const ttr2Input = document.getElementById('ttr2') as HTMLInputElement;
		const resultValue = document.querySelector('#vorgabe-result .value');

		function calculate() {
			const v1 = parseInt(ttr1Input.value) || 0;
			const v2 = parseInt(ttr2Input.value) || 0;
			
			if (v1 > 0 && v2 > 0) {
				const diff = Math.abs(v1 - v2);
				const points = Math.min(Math.floor(diff / 80), 5);
				if (resultValue) resultValue.textContent = points.toString();
			} else {
				if (resultValue) resultValue.textContent = '0';
			}
		}

		ttr1Input?.addEventListener('input', calculate);
		ttr2Input?.addEventListener('input', calculate);
	</script>
</BaseLayout>

<style>
	.page-header {
		background: var(--gradient-hero);
		padding: var(--space-16) 0 var(--space-8);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-12);
	}
	
	.text-center { text-align: center; }
	.pt-0 { padding-top: 0; }

	.lead-text {
		font-size: var(--text-xl);
		max-width: 600px;
		margin: 0 auto;
	}

	.calculator-box {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	label {
		font-weight: 600;
		font-size: var(--text-sm);
	}

	input {
		padding: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 8px;
		background: var(--color-bg);
		font-size: var(--text-lg);
		font-weight: 700;
	}

	.result-box {
		margin-top: 1rem;
		background: var(--color-primary);
		color: white;
		padding: 2rem;
		border-radius: 16px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		box-shadow: var(--shadow-md);
	}

	.result-box .label {
		font-size: var(--text-sm);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.9;
	}

	.result-box .value {
		font-size: var(--text-4xl);
		font-weight: 800;
	}

	.info-note {
		text-align: center;
		color: var(--color-text-muted);
	}
</style>
