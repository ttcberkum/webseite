)}
{name === 'archive' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<polyline points="21 8 21 21 3 21 3 8"/>
		<rect x="1" y="3" width="22" height="5"/>
		<line x1="10" y1="12" x2="14" y2="12"/>
	</svg>
)}
{name === 'file-pdf' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
		<polyline points="14 2 14 8 20 8"/>
		<line x1="9" y1="13" x2="15" y2="13"/>
		<line x1="9" y1="17" x2="15" y2="17"/>
	</svg>
)}
{name === 'car' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M5 17h14M6 11l2-5h8l2 5M7 11h10v6H7z"/>
		<circle cx="8.5" cy="14.5" r="1"/>
		<circle cx="15.5" cy="14.5" r="1"/>
	</svg>
)}
{name === 'bike' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<circle cx="5.5" cy="17.5" r="3.5"/>
		<circle cx="18.5" cy="17.5" r="3.5"/>
		<path d="M15 6h3M9 18l4-9 4 9M9 18l-3-5"/>
	</svg>
)}
{name === 'foot' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<circle cx="13" cy="4" r="2"/>
		<path d="M9 22l3-7 3 4 4-1M9 12l3-4 3 4M7 17l4-2"/>
	</svg>
)}
{name === 'train' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<rect x="4" y="3" width="16" height="16" rx="2"/>
		<line x1="4" y1="11" x2="20" y2="11"/>
		<circle cx="8.5" cy="15" r="1"/>
		<circle cx="15.5" cy="15" r="1"/>
		<path d="M8 19l-2 3M16 19l2 3"/>
	</svg>
)}
{name === 'chevron-down' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<polyline points="6 9 12 15 18 9"/>
	</svg>
)}
{name === 'chevron-left' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<polyline points="15 18 9 12 15 6"/>
	</svg>
)}
{name === 'chevron-right' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<polyline points="9 18 15 12 9 6"/>
	</svg>
)}
