---
/**
 * Zentrale Icon-Komponente. Alle SVGs nutzen `currentColor` und respektieren
 * die `width`-Prop. Neue Icons hier einmal ergänzen — sind dann überall verfügbar.
 *
 * Verwendung:
 *   <Icon name="mail" size={20} />
 *   <Icon name="arrow-right" class="custom-class" />
 */
interface Props {
	name: string;
	size?: number;
	class?: string;
	'aria-label'?: string;
}

const { name, size = 20, class: className = '', 'aria-label': ariaLabel } = Astro.props;
const ariaHidden = ariaLabel ? undefined : 'true';
---

{name === 'mail' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
		<polyline points="22,6 12,13 2,6"/>
	</svg>
)}
{name === 'phone' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
	</svg>
)}
{name === 'map-pin' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
		<circle cx="12" cy="10" r="3"/>
	</svg>
)}
{name === 'calendar' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<rect x="3" y="4" width="18" height="18" rx="2"/>
		<line x1="16" y1="2" x2="16" y2="6"/>
		<line x1="8" y1="2" x2="8" y2="6"/>
		<line x1="3" y1="10" x2="21" y2="10"/>
	</svg>
)}
{name === 'chart' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<line x1="18" y1="20" x2="18" y2="10"/>
		<line x1="12" y1="20" x2="12" y2="4"/>
		<line x1="6" y1="20" x2="6" y2="14"/>
		<line x1="3" y1="20" x2="21" y2="20"/>
	</svg>
)}
{name === 'team' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
		<circle cx="9" cy="7" r="4"/>
		<path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
		<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
	</svg>
)}
{name === 'info' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<circle cx="12" cy="12" r="10"/>
		<line x1="12" y1="16" x2="12" y2="12"/>
		<line x1="12" y1="8" x2="12.01" y2="8"/>
	</svg>
)}
{name === 'trophy' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z"/>
		<path d="M7 6H5a2 2 0 0 0-2 2v1a3 3 0 0 0 3 3h1"/>
		<path d="M17 6h2a2 2 0 0 1 2 2v1a3 3 0 0 1-3 3h-1"/>
	</svg>
)}
{name === 'arrow-up-right' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<line x1="7" y1="17" x2="17" y2="7"/>
		<polyline points="7 7 17 7 17 17"/>
	</svg>
)}
{name === 'arrow-right' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<line x1="5" y1="12" x2="19" y2="12"/>
		<polyline points="12 5 19 12 12 19"/>
	</svg>
)}
{name === 'eye' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
		<circle cx="12" cy="12" r="3"/>
	</svg>
)}
{name === 'download' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
		<polyline points="7 10 12 15 17 10"/>
		<line x1="12" y1="15" x2="12" y2="3"/>
	</svg>
)}
{name === 'clock' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<circle cx="12" cy="12" r="10"/>
		<polyline points="12 6 12 12 16 14"/>
	</svg>
)}
{name === 'refresh' && (
	<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden={ariaHidden} aria-label={ariaLabel}>
		<polyline points="23 4 23 10 17 10"/>
		<polyline points="1 20 1 14 7 14"/>
		<path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/>
		<path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/>
