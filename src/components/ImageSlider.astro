---
interface Slide {
	src: string;
	alt: string;
	caption?: string;
}

interface Props {
	slides: Slide[];
	interval?: number;
	ratio?: string;
	className?: string;
}

const { slides, interval = 5000, ratio = '4 / 3', className = '' } = Astro.props;
---

<div class={`slider ${className}`} data-slider data-interval={interval} style={`--slider-ratio: ${ratio};`}>
	<div class="slider__track" aria-live="polite">
		{slides.map((slide, i) => (
			<figure class:list={['slider__slide', { 'is-active': i === 0 }]} aria-hidden={i === 0 ? 'false' : 'true'}>
				<img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} draggable="false" />
				{slide.caption && <figcaption>{slide.caption}</figcaption>}
			</figure>
		))}
	</div>

	<button class="slider__btn slider__btn--prev" data-slider-prev type="button" aria-label="Vorheriges Bild">
		<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<polyline points="15 18 9 12 15 6"/>
		</svg>
	</button>
	<button class="slider__btn slider__btn--next" data-slider-next type="button" aria-label="Nächstes Bild">
		<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<polyline points="9 18 15 12 9 6"/>
		</svg>
	</button>

	<div class="slider__dots" role="tablist">
		{slides.map((_, i) => (
			<button
				type="button"
				class:list={['slider__dot', { 'is-active': i === 0 }]}
				data-slider-dot={i}
				role="tab"
				aria-label={`Bild ${i + 1} von ${slides.length} anzeigen`}
				aria-selected={i === 0 ? 'true' : 'false'}
			></button>
		))}
	</div>
</div>
