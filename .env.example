# Google-Kalender mit Vereinsterminen (iCal-Feed).
# Im Google Kalender unter "Einstellungen" → Kalender wählen → "Integration":
# "Geheime Adresse im iCal-Format" oder "Öffentliche Adresse im iCal-Format" kopieren.
# Bei Cloudflare Pages: als Production- und Preview-Environment-Variable hinterlegen.
GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/...basic.ics
